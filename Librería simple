    function Tab:AddKeybind(title, callback, options, desc)
        callback = callback or function() end
        options  = options or {}
        local ctrl    = {}
        local current = options.standard or Enum.KeyCode.RightShift
        local picking = false
        local kb = Library._currentKeybindState or {}

        local row = makeRow(scroll, title, desc, 36)

        local names = {
            RightControl="RCtrl", LeftControl="LCtrl",
            LeftShift="LShift",   RightShift="RShift",
            MouseButton1="M1",    MouseButton2="M2",
        }

        local kbBtn = Instance.new("TextButton")
        kbBtn.Size             = UDim2.new(0, 80, 0, 24)
        kbBtn.AnchorPoint      = Vector2.new(1, 0.5)
        kbBtn.Position         = UDim2.new(1, -10, 0.5, 0)
        kbBtn.BackgroundColor3 = Defaults.surface
        kbBtn.BorderSizePixel  = 0
        kbBtn.Text             = names[current.Name] or current.Name
        kbBtn.TextColor3       = theme.main_color
        kbBtn.TextSize         = 12
        kbBtn.Font             = Enum.Font.GothamBold
        kbBtn.AutoButtonColor  = false
        kbBtn.ZIndex           = row.ZIndex + 1
        makeRound(kbBtn, 5)
        makeStroke(kbBtn, Defaults.border, 1, 0)
        kbBtn.Parent = row

        local globalBinding = false

        kbBtn.MouseButton1Click:Connect(function()
            if globalBinding then return end
            globalBinding = true
            picking = true
            kbBtn.Text = "..."
            kbBtn.TextColor3 = Defaults.subtext
            local conn; conn = UIS.InputBegan:Connect(function(inp, gp)
                if gp then return end
                if inp.UserInputType == Enum.UserInputType.MouseButton1 and inp ~= kbBtn then
                    conn:Disconnect()
                    globalBinding = false
                    return
                end
                if inp.KeyCode and inp.KeyCode ~= Enum.KeyCode.Unknown then
                    current = inp.KeyCode
                    local n = names[current.Name] or current.Name
                    kbBtn.Text = n
                    kbBtn.TextColor3 = theme.main_color
                    picking = false
                    globalBinding = false
                    conn:Disconnect()
                end
            end)
        end)

        addSignal(UIS.InputBegan:Connect(function(inp, gp)
            if gp or picking then return end
            if inp.KeyCode == current then
                pcall(callback, current)
            end
        end))

        function ctrl:SetKeybind(kc)
            current = kc
            kbBtn.Text = names[kc.Name] or kc.Name
            kbBtn.TextColor3 = theme.main_color
        end

        function ctrl:Get() return current end

        return ctrl, kbBtn
    end

