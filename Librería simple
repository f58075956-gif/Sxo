--  ROW (base de cada elemento en la tab)
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
local function makeRow(parent, title, desc, height)
    height = height or 36
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1,0,0,height)
    row.BackgroundColor3 = Defaults.bg2
    row.BorderSizePixel  = 0
    row.Parent           = parent
    makeRound(row, 6)
    makeStroke(row, Defaults.border, 1, 0.6)
    makePadding(row, 10, 0)

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size              = UDim2.new(0.55, 0, 1, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text              = title or ""
    titleLabel.TextColor3        = Defaults.text
    titleLabel.TextSize          = 13
    titleLabel.Font              = Enum.Font.Gotham
    titleLabel.TextXAlignment    = Enum.TextXAlignment.Left
    titleLabel.Parent            = row

    if desc and desc ~= "" then
        row.Size = UDim2.new(1,0,0, height + 14)
        local descLabel = Instance.new("TextLabel")
        descLabel.Size           = UDim2.new(1,0,0,12)
        descLabel.Position       = UDim2.new(0,0,1,-16)
        descLabel.BackgroundTransparency = 1
        descLabel.Text           = desc
        descLabel.TextColor3     = Defaults.subtext
        descLabel.TextSize       = 11
        descLabel.Font           = Enum.Font.Gotham
        descLabel.TextXAlignment = Enum.TextXAlignment.Left
        descLabel.Parent         = row
    end

    return row, titleLabel
end

