    function Tab:AddSlider(title, callback, options, desc)
        callback = callback or function() end
        options  = options or {}
        local minV  = options.min or 0
        local maxV  = options.max or 100
        local ctrl  = {}

        local row = makeRow(scroll, title, desc, 44)

        -- Valor actual
        local valLabel = Instance.new("TextLabel")
        valLabel.Size             = UDim2.new(0, 40, 0, 14)
        valLabel.AnchorPoint      = Vector2.new(1, 0)
        valLabel.Position         = UDim2.new(1, -10, 0, 6)
        valLabel.BackgroundTransparency = 1
        valLabel.Text             = tostring(minV)
        valLabel.TextColor3       = theme.main_color
        valLabel.TextSize         = 12
        valLabel.Font             = Enum.Font.GothamBold
        valLabel.TextXAlignment   = Enum.TextXAlignment.Right
        valLabel.ZIndex           = row.ZIndex + 1
        valLabel.Parent           = row

        -- Track del slider
        local trackBg = Instance.new("Frame")
        trackBg.Size             = UDim2.new(1, -20, 0, 6)
        trackBg.AnchorPoint      = Vector2.new(0, 1)
        trackBg.Position         = UDim2.new(0, 0, 1, -8)
        trackBg.BackgroundColor3 = Defaults.surface
        trackBg.BorderSizePixel  = 0
        trackBg.ZIndex           = row.ZIndex + 1
        makeRound(trackBg, 3)
        makeStroke(trackBg, Defaults.border, 1, 0.4)
        trackBg.Parent = row

        local trackFill = Instance.new("Frame")
        trackFill.Size             = UDim2.new(0, 0, 1, 0)
        trackFill.BackgroundColor3 = theme.main_color
        trackFill.BorderSizePixel  = 0
        makeRound(trackFill, 3)
        trackFill.Parent = trackBg

        local thumb2 = Instance.new("Frame")
        thumb2.Size           = UDim2.new(0,12,0,12)
        thumb2.AnchorPoint    = Vector2.new(0.5, 0.5)
        thumb2.Position       = UDim2.new(0,0,0.5,0)
        thumb2.BackgroundColor3 = Color3.new(1,1,1)
        thumb2.BorderSizePixel = 0
        thumb2.ZIndex         = trackBg.ZIndex + 2
        makeRound(thumb2, 6)
        thumb2.Parent = trackBg

        local currentValue = minV
        local dragging     = false
        local wasInside    = false

        local function setValue(pct)
            pct = math.clamp(pct, 0, 1)
            currentValue = math.floor(minV + (maxV - minV) * pct)
            trackFill.Size = UDim2.new(pct, 0, 1, 0)
            thumb2.Position = UDim2.new(pct, 0, 0.5, 0)
            valLabel.Text  = tostring(currentValue)
            pcall(callback, currentValue)
        end

        local heartbeat
        local mouseDown = false
        trackBg.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                mouseDown = true
                local px = mousePos()
                local pct = (px.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X
                setValue(pct)
            end
        end)

        addSignal(UIS.InputChanged:Connect(function(inp)
            if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local px = mousePos()
                local pct = (px.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X
                setValue(pct)
            end
        end))

        addSignal(UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end))

        function ctrl:Set(val)
            val = tonumber(val) or minV
            local pct = (val - minV) / (maxV - minV)
            setValue(pct)
        end

        function ctrl:Get() return currentValue end

        ctrl:Set(options.default or minV)
        return ctrl
    end

