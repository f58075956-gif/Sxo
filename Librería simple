local function tween(obj, props, t)
    t = t or 0.12
    if t == 0 then for k,v in pairs(props) do obj[k]=v end; return end
    TW:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function mousePos()
    local p = UIS:GetMouseLocation()
    return Vector2.new(p.X, p.Y - 36)
end

local function ripple(parent, mx, my)
    task.spawn(function()
        local old = parent.ClipsDescendants
        parent.ClipsDescendants = true
        local c = Instance.new("Frame")
        c.AnchorPoint = Vector2.new(0.5,0.5)
        c.BackgroundColor3 = Color3.new(1,1,1)
        c.BackgroundTransparency = 0.7
        c.BorderSizePixel = 0
        c.ZIndex = parent.ZIndex + 20
        local px = mx - parent.AbsolutePosition.X
        local py = my - parent.AbsolutePosition.Y
        c.Size = UDim2.new(0,1,0,1)
        c.Position = UDim2.new(0, px, 0, py)
        c.Parent = parent
        Instance.new("UICorner", c).CornerRadius = UDim.new(1,0)
        local r = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.6
        c:TweenSizeAndPosition(
            UDim2.new(0,r,0,r),
            UDim2.new(0, px-r/2, 0, py-r/2),
            Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.45, false
        )
        tween(c, {BackgroundTransparency=1}, 0.45)
        task.wait(0.45)
        c:Destroy()
        parent.ClipsDescendants = old
    end)
end

