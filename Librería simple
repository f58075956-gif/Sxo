        local function updatePanelSize()
            local h = math.min(panelList.AbsoluteContentSize.Y + 8, 180)
            if isOpen then
                tween(panel, {Size = UDim2.new(0,130,0,h)}, theme.tween_time)
                wrapper.Size = UDim2.new(1,0,0, 36 + h + 4)
            end
        end

        local function open()
            isOpen = true
            panel.Visible = true
            updatePanelSize()
            tween(arrow, {Rotation = 180}, theme.tween_time)
        end

        local function close()
            isOpen = false
            local h = panelList.AbsoluteContentSize.Y + 8
            tween(panel, {Size = UDim2.new(0,130,0,0)}, theme.tween_time)
            tween(arrow, {Rotation = 0}, theme.tween_time)
            task.delay(theme.tween_time, function()
                panel.Visible = false
                wrapper.Size = UDim2.new(1,0,0,36)
            end)
        end

        dropBtn.MouseButton1Click:Connect(function()
            if isOpen then close() else open() end
        end)

        function ctrl:Add(itemName)
            itemName = tostring(itemName)
            local btn = Instance.new("TextButton")
            btn.Size             = UDim2.new(1,-0,0,22)
            btn.BackgroundColor3 = Defaults.bg2
            btn.BackgroundTransparency = 1
            btn.BorderSizePixel  = 0
