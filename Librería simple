            sample.BackgroundColor3  = color
            palette.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            satBar.ImageColor3       = Color3.fromHSV(h, 1, 1)
            cursor.Position          = UDim2.new(s, 0, 1-v, 0)
            satIndicator.Position    = UDim2.new(-0.12, 0, 1-v, -1)
            hueIndicator.Position    = UDim2.new(h, -1, -0.15, 0)
            pcall(callback, color)
        end

        local dragPalette, dragHue, dragSat = false, false, false

        palette.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragPalette = true end
        end)
        hueBar.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragHue = true end
        end)
        satBar.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragSat = true end
        end)

        addSignal(UIS.InputChanged:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
            local mp = mousePos()
            if dragPalette then
                s = math.clamp((mp.X - palette.AbsolutePosition.X) / palette.AbsoluteSize.X, 0, 1)
                v = 1 - math.clamp((mp.Y - palette.AbsolutePosition.Y) / palette.AbsoluteSize.Y, 0, 1)
                updateColor()
            end
            if dragHue then
                h = math.clamp((mp.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                updateColor()
            end
            if dragSat then
                v = 1 - math.clamp((mp.Y - satBar.AbsolutePosition.Y) / satBar.AbsoluteSize.Y, 0, 1)
                updateColor()
            end
        end))

        addSignal(UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragPalette = false
                dragHue     = false
                dragSat     = false
            end
        end))

        local panelOpen = false
        sample.MouseButton1Click:Connect(function()
            panelOpen = not panelOpen
            panel.Visible = panelOpen
        end)

        function ctrl:Set(color)
            if typeof(color) == "Color3" then
                h, s, v = Color3.toHSV(color)
                updateColor()
            end
        end

        function ctrl:Get()
            return Color3.fromHSV(h, s, v)
        end

        return ctrl, sample
    end

