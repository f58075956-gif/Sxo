            tabBar.Visible   = false
            tabLine.Visible  = false
        else
            tween(root, {Size = UDim2.new(0, root.AbsoluteSize.X, 0, savedHeight)}, theme.tween_time)
            content.Visible  = true
            tabBar.Visible   = true
            tabLine.Visible  = true
        end
    end)

    -- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    --  OBJETO VENTANA
    -- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    local Window   = {}
    local tabs     = {}
    local activeTab = nil

    local function selectTab(tabObj)
        if activeTab == tabObj then return end
        -- Ocultar tab actual
        if activeTab then
            activeTab._scroll.Visible = false
            activeTab._btn.TextColor3 = Defaults.subtext
            activeTab._btn.BackgroundTransparency = 1
        end
        activeTab = tabObj
        tabObj._scroll.Visible = true
        tween(tabObj._btn, {TextColor3 = theme.main_color, BackgroundTransparency=0.85}, 0.1)
        tabObj._btn.BackgroundColor3 = theme.main_color
    end

    function Window:AddTab(tabTitle, icon)
        -- BotÃ³n de la pestaÃ±a
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(0, 0, 1, -4)
        btn.AutomaticSize    = Enum.AutomaticSize.X
        btn.BackgroundColor3 = theme.main_color
        btn.BackgroundTransparency = 1
        btn.BorderSizePixel  = 0
        btn.Text             = (icon and icon ~= "" and icon .. "  " or "") .. (tabTitle or "Tab")
        btn.TextColor3       = Defaults.subtext
        btn.TextSize         = 12
        btn.Font             = Enum.Font.GothamBold
        btn.AutoButtonColor  = false
        btn.ZIndex           = tabBar.ZIndex + 1
        makeRound(btn, 5)
        makePadding(btn, 10, 0)
        btn.Parent = tabScroll

        -- Actualizar canvas
        tabList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            tabScroll.CanvasSize = UDim2.new(0, tabList.AbsoluteContentSize.X + 8, 1, 0)
        end)

        -- Crear la tab
        local Tab = buildTab(content, theme)
        Tab._btn  = btn

        btn.MouseEnter:Connect(function()
            if activeTab ~= Tab then
                tween(btn, {TextColor3 = Defaults.text}, 0.08)
            end
        end)
        btn.MouseLeave:Connect(function()
            if activeTab ~= Tab then
                tween(btn, {TextColor3 = Defaults.subtext}, 0.08)
            end
        end)
        btn.MouseButton1Click:Connect(function()
            selectTab(Tab)
        end)

        table.insert(tabs, Tab)
        if #tabs == 1 then selectTab(Tab) end

        return Tab
    end

    function Window:SelectTab(index)
        if tabs[index] then selectTab(tabs[index]) end
    end

    function Window:SetTitle(newTitle)
        titleLabel.Text = newTitle
    end

    function Window:Destroy()
        root:Destroy()
    end

    function Window:Toggle()
        root.Visible = not root.Visible
    end

    table.insert(Library._windows, Window)
    return Window
end

