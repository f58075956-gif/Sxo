            btn.ZIndex           = panel.ZIndex + 1
            btn.AutoButtonColor  = false
            makeRound(btn, 4)
            makePadding(btn, 8, 0)
            btn.Parent = panel

            btn.MouseEnter:Connect(function()
                tween(btn, {BackgroundColor3 = Defaults.surface, BackgroundTransparency=0}, 0.08)
            end)
            btn.MouseLeave:Connect(function()
                if selected ~= itemName then
                    tween(btn, {BackgroundTransparency=1}, 0.08)
                end
            end)
            btn.MouseButton1Click:Connect(function()
                selected = itemName
                dropBtn.Text = itemName
                dropBtn.TextColor3 = Defaults.text
                -- Resetear todos
                for _, c in ipairs(panel:GetChildren()) do
                    if c:IsA("TextButton") then
                        tween(c, {BackgroundColor3=Defaults.surface, BackgroundTransparency=1}, 0.08)
                        c.TextColor3 = Defaults.text
                    end
                end
                btn.BackgroundTransparency = 0
                btn.BackgroundColor3 = theme.main_color:Lerp(Defaults.surface, 0.6)
                btn.TextColor3 = theme.main_color
                close()
                pcall(callback, itemName)
            end)

            table.insert(items, {name=itemName, btn=btn})
            updatePanelSize()
            local btnCtrl = {}
            function btnCtrl:Remove() btn:Destroy() end
            return btn, btnCtrl
        end

        function ctrl:Remove(name)
            for i,item in ipairs(items) do
                if item.name == name then
                    item.btn:Destroy()
                    table.remove(items, i)
                    break
                end
            end
            updatePanelSize()
        end

        function ctrl:SetValue(name)
            dropBtn.Text = name
            dropBtn.TextColor3 = Defaults.text
            selected = name
            pcall(callback, name)
        end

        function ctrl:Get() return selected end

        return ctrl, dropBtn
    end

