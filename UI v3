                local function sv(pct)
                    pct=math.clamp(pct,0,1)
                    local f=10^rnd; local v=math.floor((minV+(maxV-minV)*pct)*f+0.5)/f
                    T(fi,{Size=UDim2.fromScale(pct,1)},0.05); dt.Position=UDim2.new(pct,-6,0.5,0)
                    vl.Text=tostring(v); pcall(cb,v)
