            if desc and #desc > 0 then
                Lbl({ Text=desc, Size=UDim2.new(1,-170,0,12), Position=UDim2.fromOffset(14,24),
                    TextColor3=theme.SubText, Font=Enum.Font.Gotham, TextSize=11 }, el)
            end

            -- Display del valor (alineado derecha como Fluent)
            local valDisplay = Lbl({
                Text=tostring(defV),
                Size=UDim2.fromOffset(100,14),
                Position=UDim2.new(1,-4,0,10),
                AnchorPoint=Vector2.new(1,0),
                TextColor3=theme.SubText,
                Font=Enum.Font.Gotham,
                TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Right,
            }, el)

            -- Rail (igual estructura que Fluent: dentro del rail hay fill+dot)
            local rail = Fr({
                Size=UDim2.new(1,-28,0,4),
                AnchorPoint=Vector2.new(1,0),
                Position=UDim2.new(1,-14,0,34),
                BackgroundColor3=theme.SliderRail,
                BackgroundTransparency=0.4,
            }, el)
            C(4,rail)
            -- Constraint de tamaÃ±o igual que Fluent
            local sc2 = Instance.new("UISizeConstraint"); sc2.MaxSize=Vector2.new(math.huge,4); sc2.Parent=rail

            local fill = Fr({ Size=UDim2.fromScale(0,1), BackgroundColor3=theme.Accent }, rail)
            C(4,fill)

            -- Dot (cÃ­rculo en la posiciÃ³n del valor)
            local dot = Instance.new("ImageLabel")
            dot.Image = "http://www.roblox.com/asset/?id=12266946128"
            dot.Size = UDim2.fromOffset(14,14)
            dot.AnchorPoint = Vector2.new(0,0.5)
            dot.Position = UDim2.new(0,-7,0.5,0)
            dot.BackgroundTransparency = 1
            dot.ImageColor3 = theme.Accent
            dot.ZIndex = 2
            dot.Parent = rail

            local function round2(v)
                if round == 0 then return math.floor(v+0.5) end
                local f = 10^round; return math.floor(v*f+0.5)/f
            end

            local function setSlider(pct)
                pct = math.clamp(pct,0,1)
                local v = round2(minV+(maxV-minV)*pct)
                T(fill,{Size=UDim2.fromScale(pct,1)},0.05)
                dot.Position = UDim2.new(pct,-7,0.5,0)
                valDisplay.Text = tostring(v)
                pcall(callback,v)
            end

            local initPct = math.clamp((defV-minV)/math.max(maxV-minV,0.001),0,1)
            fill.Size = UDim2.fromScale(initPct,1)
            dot.Position = UDim2.new(initPct,-7,0.5,0)
            valDisplay.Text = tostring(defV)

