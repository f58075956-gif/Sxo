--  ELEMENT BASE â€” igual al Element.lua de Fluent
--  Fondo redondeado + tÃ­tulo + descripciÃ³n opcional
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
local function mkElement(title, desc, theme, parent, height)
    height = height or 38

    local el = Btn({
        Size = UDim2.new(1, 0, 0, height),
        BackgroundColor3 = theme.ElementBg,
        LayoutOrder = 0,
    }, parent)
    C(8, el)
    S(theme.ElementStroke, 1, 0.6, el)

    -- Hover
    el.MouseEnter:Connect(function() T(el, {BackgroundColor3 = theme.ElementHover}) end)
    el.MouseLeave:Connect(function() T(el, {BackgroundColor3 = theme.ElementBg}) end)

    -- TÃ­tulo
    local titleLbl = Lbl({
        Text = title or "",
        Size = UDim2.new(1, -120, 0, 14),
        Position = UDim2.fromOffset(14, desc and 10 or 0),
        TextColor3 = theme.Text,
        Font = Enum.Font.GothamSemibold,
        TextSize = 13,
    }, el)
    if not desc then titleLbl.Size = UDim2.new(1, -120, 1, 0) end

    -- DescripciÃ³n
    local descLbl
    if desc and #desc > 0 then
        descLbl = Lbl({
            Text = desc,
            Size = UDim2.new(1, -120, 0, 12),
            Position = UDim2.fromOffset(14, 22),
            TextColor3 = theme.SubText,
            Font = Enum.Font.Gotham,
            TextSize = 11,
        }, el)
        el.Size = UDim2.new(1, 0, 0, math.max(height, 46))
    end

    return el, titleLbl, descLbl
end

