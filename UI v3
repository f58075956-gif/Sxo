                local defV = cfg2.default or minV
                local round = cfg2.rounding or 1
                local el = mkChildEl(54)
                el.Size = UDim2.new(1,0,0,54)
                Label({ Text = text, Size = UDim2.new(0.6,0,0,22), Position = UDim2.fromOffset(10,4),
                    TextColor3 = theme.Text, Font = Enum.Font.GothamSemibold, TextSize = 12 }, el)
                local vl = Label({ Text = tostring(defV), Size = UDim2.new(0.4,-10,0,22),
                    Position = UDim2.new(0.6,0,0,4), TextColor3 = theme.Accent,
                    Font = Enum.Font.GothamBold, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right }, el)
                local sbg = Frame({ Size = UDim2.new(1,-20,0,5), Position = UDim2.new(0,10,0,36),
                    BackgroundColor3 = theme.SliderBg }, el)
                Corner(3, sbg)
                local fill = Frame({ Size = UDim2.fromScale(0,1), BackgroundColor3 = theme.SliderFill }, sbg)
                Corner(3, fill)
                local thmb = Frame({ Size = UDim2.fromOffset(12,12), AnchorPoint = Vector2.new(0.5,0.5),
                    Position = UDim2.new(0,0,0.5,0), BackgroundColor3 = Color3.fromRGB(255,255,255), ZIndex=2 }, sbg)
                Corner(6, thmb)
                local function setVal(pct)
                    pct = math.clamp(pct,0,1)
                    Tween(fill,{Size=UDim2.fromScale(pct,1)},0.08)
                    Tween(thmb,{Position=UDim2.new(pct,0,0.5,0)},0.08)
                    local factor = 10^round
                    local val = math.floor((minV+(maxV-minV)*pct)*factor+0.5)/factor
                    vl.Text = tostring(val); pcall(cb,val)
                end
                local initP = math.clamp((defV-minV)/math.max(maxV-minV,0.001),0,1)
                fill.Size = UDim2.fromScale(initP,1); thmb.Position = UDim2.new(initP,0,0.5,0)
                local sliding = false
                sbg.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true end end)
                UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end end)
                UIS.InputChanged:Connect(function(i)
                    if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then
                        setVal((i.Position.X-sbg.AbsolutePosition.X)/sbg.AbsoluteSize.X)
                    end
                end)
                local ctrl = {}; function ctrl:Set(v) setVal(math.clamp((v-minV)/math.max(maxV-minV,0.001),0,1)) end
                return ctrl, el
            end

            return Folder, folder
        end

        return Tab
    end

    return Tabs, mainFrame, sg
end

