            function Folder:AddSlider(title,opts2,cb)
                opts2=opts2 or{}; cb=cb or function()end
                local minV=opts2.Min or 0; local maxV=opts2.Max or 100
                local defV=opts2.Default or minV; local rnd=opts2.Rounding or 0
