                    BackgroundColor3=theme.ElementHover, ZIndex=32 }, dropFrame)
                C(6,row)
                rows[item] = row

                -- Checkbox (solo multi)
                local chkFrame, chkMark
                if multi then
                    chkFrame = Fr({ Size=UDim2.fromOffset(14,14), Position=UDim2.fromOffset(6,7),
                        BackgroundColor3=theme.ElementBg, ZIndex=34 }, row)
                    C(4,chkFrame); S(theme.ElementStroke,1,0.4,chkFrame)
                    chkMark = Lbl({ Text="âœ“", Size=UDim2.fromScale(1,1), TextColor3=theme.Accent,
                        Font=Enum.Font.GothamBold, TextSize=9, TextXAlignment=Enum.TextXAlignment.Center,
                        Visible=false, ZIndex=35 }, chkFrame)
                end

                local xOff = multi and 26 or 8
                Lbl({ Text=item, Size=UDim2.new(1,-xOff-8,1,0), Position=UDim2.fromOffset(xOff,0),
                    TextColor3=theme.Text, Font=Enum.Font.Gotham, TextSize=12, ZIndex=33 }, row)

                row.MouseEnter:Connect(function() T(row,{BackgroundTransparency=0.7}) end)
                row.MouseLeave:Connect(function() T(row,{BackgroundTransparency=1}) end)
                row.MouseButton1Click:Connect(function()
                    if multi then
                        if selectedMulti[item] then
                            selectedMulti[item]=nil
                            if chkMark then chkMark.Visible=false end
                            if chkFrame then T(chkFrame,{BackgroundColor3=theme.ElementBg}) end
                        else
                            selectedMulti[item]=true
                            if chkMark then chkMark.Visible=true end
                            if chkFrame then T(chkFrame,{BackgroundColor3=theme.Accent}) end
                        end
                        updateSelLabel()
                        pcall(callback, selectedMulti)
                    else
                        selected=item
                        updateSelLabel()
                        closeD()
                        pcall(callback,item)
                    end
                end)
            end

            for _,v in ipairs(values) do addItem(v) end

            -- Default multi
            if opts.Default and multi and type(opts.Default)=="table" then
                for _,v in ipairs(opts.Default) do selectedMulti[v]=true end
                updateSelLabel()
            end

            function DD:Add(item) addItem(item); return self end
            function DD:Remove(item)
                local row = rows[item]
                if row then
                    row:Destroy()
                    rows[item] = nil
                    for i,v in ipairs(items) do
                        if v == item then table.remove(items,i); break end
                    end
                    if selected == item then
                        selected = items[1]
                        updateSelLabel()
                        pcall(callback, selected)
                    end
                end
            end
            function DD:SetValue(v)
                if multi and type(v)=="table" then selectedMulti=v
                else selected=v end
                updateSelLabel()
            end
            function DD:GetValue() return multi and selectedMulti or selected end

            return DD, el
        end

