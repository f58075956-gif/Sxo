        function Tab:AddKeybind(title, callback, opts)
            opts = opts or {}
            callback = callback or function() end
            local current = opts.standard or Enum.KeyCode.F
            local desc = opts.desc
            local binding = false
            local mode = "Always" -- Always / Toggle / Hold
            local togState = false

            local el, titleLbl3 = mkElement(title, desc, theme, tabContent)

            local kbBtn = Btn({
                Text=current.Name,
                Size=UDim2.fromOffset(90,24),
                AnchorPoint=Vector2.new(1,0.5),
                Position=UDim2.new(1,-12,0.5,0),
                BackgroundColor3=theme.ElementBg,
                TextColor3=theme.Accent,
                Font=Enum.Font.GothamBold,
                TextSize=11,
                ZIndex=3,
            }, el)
            C(7,kbBtn); S(theme.ElementStroke,1,0.5,kbBtn)

            kbBtn.MouseButton1Click:Connect(function()
                if binding then return end
                binding=true; kbBtn.Text="..."; kbBtn.TextColor3=theme.SubText
                local conn
                conn=UIS.InputBegan:Connect(function(inp,gp)
                    if gp then return end
                    current=inp.KeyCode
                    kbBtn.Text=current.Name; kbBtn.TextColor3=theme.Accent
                    binding=false; conn:Disconnect()
                end)
            end)

            UIS.InputBegan:Connect(function(inp,gp)
                if gp or binding then return end
                if inp.KeyCode==current then
                    if mode=="Toggle" then
                        togState=not togState; pcall(callback,togState)
                    else
                        pcall(callback,true)
                    end
                end
            end)
            UIS.InputEnded:Connect(function(inp)
                if inp.KeyCode==current and mode=="Hold" then
                    pcall(callback,false)
                end
            end)

            local ctrl={}
            function ctrl:SetValue(kc,m)
                current=kc; kbBtn.Text=kc.Name
                if m then mode=m end
            end
            function ctrl:GetState() return togState end
            function ctrl:OnClick(fn) callback=fn end
            return ctrl, el
        end

