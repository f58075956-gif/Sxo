                local function set(v)
                    st=v; T(tr,{BackgroundTransparency=st and 0 or 1},0.25)
                    T(ci,{Position=UDim2.new(0,st and 19 or 2,0.5,0),ImageColor3=st and theme.ToggleToggled or theme.ToggleSlider},0.25)
