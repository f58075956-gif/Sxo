        -- â”€â”€ SLIDER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        function Tab:AddSlider(text, callback, cfg2)
            cfg2 = cfg2 or {}
            local minV   = cfg2.min or 0
            local maxV   = cfg2.max or 100
            local defV   = cfg2.default or minV
            local round  = cfg2.rounding or 1
            callback = callback or function() end

            local el = mkElement(22)
            el.Size = UDim2.new(1, 0, 0, 58)

            Label({
                Text = text,
                Size = UDim2.new(0.6, 0, 0, 26),
                Position = UDim2.fromOffset(14, 6),
                TextColor3 = theme.Text,
                Font = Enum.Font.GothamSemibold,
                TextSize = 13,
            }, el)

            local valLabel = Label({
                Text = tostring(defV),
                Size = UDim2.new(0.4, -14, 0, 26),
                Position = UDim2.new(0.6, 0, 0, 6),
                TextColor3 = theme.Accent,
                Font = Enum.Font.GothamBold,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Right,
            }, el)

            -- Track
            local sliderBg = Frame({
                Size = UDim2.new(1, -28, 0, 6),
                Position = UDim2.new(0, 14, 0, 38),
                BackgroundColor3 = theme.SliderBg,
            }, el)
            Corner(3, sliderBg)

            local fill = Frame({
                Size = UDim2.fromScale(0, 1),
                BackgroundColor3 = theme.SliderFill,
            }, sliderBg)
            Corner(3, fill)

            -- Thumb
            local thumbS = Frame({
                Size = UDim2.fromOffset(14, 14),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(0, 0, 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                ZIndex = 2,
            }, sliderBg)
            Corner(7, thumbS)

            local function computeValue(pct)
                local range = maxV - minV
                local raw = minV + range * pct
                local factor = 10 ^ round
                return math.floor(raw * factor + 0.5) / factor
            end

            local function setSlider(pct)
                pct = math.clamp(pct, 0, 1)
                Tween(fill, {Size = UDim2.fromScale(pct, 1)}, 0.08)
                Tween(thumbS, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.08)
                local val = computeValue(pct)
                valLabel.Text = tostring(val)
                pcall(callback, val)
            end

            -- Set default
            local initPct = math.clamp((defV - minV) / math.max(maxV - minV, 0.001), 0, 1)
            fill.Size = UDim2.fromScale(initPct, 1)
            thumbS.Position = UDim2.new(initPct, 0, 0.5, 0)

            local sliding = false
            sliderBg.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true end
            end)
            UIS.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
            end)
            UIS.InputChanged:Connect(function(inp)
                if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
                    local rel = inp.Position.X - sliderBg.AbsolutePosition.X
                    setSlider(rel / sliderBg.AbsoluteSize.X)
                end
            end)

            local ctrl = {}
            function ctrl:Set(v)
                local pct = math.clamp((v - minV) / math.max(maxV - minV, 0.001), 0, 1)
                setSlider(pct)
            end
            return ctrl, el
        end

