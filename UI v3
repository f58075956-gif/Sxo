                local initP=math.clamp((defV-minV)/math.max(maxV-minV,0.001),0,1)
                fi.Size=UDim2.fromScale(initP,1); dt.Position=UDim2.new(initP,-6,0.5,0); vl.Text=tostring(defV)
                local sl=false
