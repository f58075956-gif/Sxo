--  CREATE WINDOW
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
function Library:CreateWindow(cfg)
    cfg = cfg or {}
    local theme    = Themes[cfg.Theme or "Dark"]
    local winSize  = cfg.Size or UDim2.fromOffset(580, 460)
    local TABW     = cfg.TabWidth or 160
    local TOPBARH  = 42
    local minKey   = cfg.MinimizeKey or Enum.KeyCode.RightShift

    -- ScreenGui
    local sg = Instance.new("ScreenGui")
    sg.Name = "FluentUI"
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.ResetOnSpawn = false
    sg.DisplayOrder = 100
    pcall(function() sg.Parent = CoreGui end)
    if not sg.Parent then sg.Parent = Players.LocalPlayer:WaitForChild("PlayerGui") end

    -- Root frame
    local root = Fr({
        Name = "Root",
        Size = winSize,
        Position = UDim2.fromOffset(
            math.floor((workspace.CurrentCamera.ViewportSize.X - winSize.X.Offset) / 2),
            math.floor((workspace.CurrentCamera.ViewportSize.Y - winSize.Y.Offset) / 2)
        ),
        BackgroundColor3 = theme.Background,
        ClipsDescendants = false,
    }, sg)
    C(10, root)
    S(theme.ElementStroke, 1, 0.2, root)

    -- Sombra exterior
    local shadow = Fr({
        Size = UDim2.new(1, 30, 1, 30),
        Position = UDim2.fromOffset(-15, -15),
        BackgroundColor3 = Color3.new(0,0,0),
        BackgroundTransparency = 0.55,
        ZIndex = 0,
    }, root)
    C(14, shadow)

    -- â”€â”€ TOP BAR â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local topBar = Fr({
        Size = UDim2.new(1, 0, 0, TOPBARH),
        BackgroundTransparency = 1,
        ZIndex = 5,
    }, root)

    -- LÃ­nea inferior del topBar
    Fr({
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0,0,1,-1),
        BackgroundColor3 = theme.TopBarLine,
        BackgroundTransparency = 0.5,
    }, topBar)

    -- TÃ­tulo + subtÃ­tulo en fila horizontal
    local titleRow = Fr({
        Size = UDim2.new(1, -120, 1, 0),
        Position = UDim2.fromOffset(16, 0),
        BackgroundTransparency = 1,
    }, topBar)
    local titleRowLayout = List(Enum.FillDirection.Horizontal, 5, titleRow)
    titleRowLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    Lbl({
        Text = cfg.Title or "FluentUI",
        Size = UDim2.fromScale(0, 1),
        AutomaticSize = Enum.AutomaticSize.X,
        TextColor3 = theme.Text,
        Font = Enum.Font.GothamSemibold,
        TextSize = 12,
    }, titleRow)

    if cfg.SubTitle and #cfg.SubTitle > 0 then
        Lbl({
            Text = cfg.SubTitle,
            Size = UDim2.fromScale(0, 1),
            AutomaticSize = Enum.AutomaticSize.X,
            TextColor3 = theme.SubText,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextTransparency = 0.4,
        }, titleRow)
    end

    -- Botones de barra (cerrar, minimizar)
    local function mkBarBtn(icon, xOffset, onClick)
        local btn = Btn({
            Size = UDim2.fromOffset(34, TOPBARH-8),
            AnchorPoint = Vector2.new(1,0),
            Position = UDim2.new(1, xOffset, 0, 4),
            BackgroundColor3 = theme.Text,
            BackgroundTransparency = 1,
            ZIndex = 10,
        }, topBar)
        C(7, btn)

        local ico = Instance.new("ImageLabel")
        ico.Image = icon
        ico.Size = UDim2.fromOffset(16,16)
        ico.Position = UDim2.fromScale(0.5,0.5)
        ico.AnchorPoint = Vector2.new(0.5,0.5)
        ico.BackgroundTransparency = 1
        ico.ImageColor3 = theme.Text
        ico.ZIndex = 11
        ico.Parent = btn

        btn.MouseEnter:Connect(function() T(btn,{BackgroundTransparency=0.93}) end)
        btn.MouseLeave:Connect(function() T(btn,{BackgroundTransparency=1}) end)
        btn.MouseButton1Down:Connect(function() T(btn,{BackgroundTransparency=0.97}) end)
        btn.MouseButton1Click:Connect(onClick)
        return btn, ico
    end

    -- âœ• cerrar
    mkBarBtn("rbxassetid://10723407389", -4, function()
        T(root, {Size = UDim2.fromOffset(winSize.X.Offset, 0), BackgroundTransparency=1}, 0.22)
        task.delay(0.24, function() sg:Destroy() end)
    end)

    -- â–¡ maximizar
    local maximized = false
    local savedSize, savedPos
    mkBarBtn("rbxassetid://10709791437", -40, function()
        maximized = not maximized
        if maximized then
            savedSize = root.Size; savedPos = root.Position
            T(root, {
                Size = UDim2.fromOffset(workspace.CurrentCamera.ViewportSize.X, workspace.CurrentCamera.ViewportSize.Y),
                Position = UDim2.fromOffset(0,0)
            }, 0.25)
        else
            T(root, {Size=savedSize, Position=savedPos}, 0.25)
        end
    end)

    -- â€” minimizar
    local minimized = false
    mkBarBtn("rbxassetid://10734889698", -76, function()
        minimized = not minimized
        if minimized then
            T(root, {Size = UDim2.fromOffset(winSize.X.Offset, TOPBARH)}, 0.22)
        else
            T(root, {Size = winSize}, 0.22)
        end
    end)

    -- â”€â”€ DRAG â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    do
        local dragging, dragStart, startPos
        topBar.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true; dragStart = inp.Position; startPos = root.Position
            end
        end)
        UIS.InputChanged:Connect(function(inp)
            if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local d = inp.Position - dragStart
                root.Position = UDim2.fromOffset(startPos.X.Offset+d.X, startPos.Y.Offset+d.Y)
            end
        end)
        UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)
    end

    -- â”€â”€ RESIZE (esquina inferior derecha) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local resizeGrip = Fr({
        Size = UDim2.fromOffset(16,16),
        Position = UDim2.new(1,-16,1,-16),
        BackgroundTransparency = 1,
        ZIndex = 20,
    }, root)
    -- Ãcono grip
    Lbl({ Text="â ¿", Size=UDim2.fromScale(1,1), TextColor3=theme.DimText,
        TextSize=14, TextXAlignment=Enum.TextXAlignment.Center }, resizeGrip)

    do
        local resizing, resizeStart, startSz
        resizeGrip.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing=true; resizeStart=inp.Position
                startSz=Vector2.new(root.Size.X.Offset, root.Size.Y.Offset)
            end
        end)
        UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then resizing=false end
        end)
        UIS.InputChanged:Connect(function(inp)
            if resizing and inp.UserInputType==Enum.UserInputType.MouseMovement then
                local d = inp.Position - resizeStart
                local nx = math.clamp(startSz.X+d.X, 420, 1200)
                local ny = math.clamp(startSz.Y+d.Y, 300, 900)
                root.Size = UDim2.fromOffset(nx,ny)
            end
        end)
    end

    -- â”€â”€ SIDEBAR â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local sidebar = Fr({
        Size = UDim2.new(0, TABW, 1, -TOPBARH),
        Position = UDim2.fromOffset(0, TOPBARH),
        BackgroundColor3 = theme.Sidebar,
        ClipsDescendants = true,
    }, root)

    -- LÃ­nea separadora derecha del sidebar
    Fr({
        Size = UDim2.new(0,1,1,0),
        Position = UDim2.new(1,-1,0,0),
        BackgroundColor3 = theme.TopBarLine,
        BackgroundTransparency = 0.5,
    }, sidebar)

    -- Scroll de tabs
    local tabScroll = Scr({
        Size = UDim2.new(1,0,1,-8),
        Position = UDim2.fromOffset(0,8),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.new(0,0,0,0),
        ScrollBarImageColor3 = theme.Scrollbar,
        ScrollingDirection = Enum.ScrollingDirection.Y,
    }, sidebar)
    local tabScrollLayout = List(Enum.FillDirection.Vertical, 4, tabScroll)
    Pad(0,0,12,12,tabScroll)
