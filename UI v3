local function Tween(obj, props, t)
    t = t or 0.18
    TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function Corner(r, parent)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
    return c
end

local function Pad(t, b, l, r, parent)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, t)
    p.PaddingBottom = UDim.new(0, b)
    p.PaddingLeft   = UDim.new(0, l)
    p.PaddingRight  = UDim.new(0, r)
    p.Parent = parent
    return p
end

local function Frame(props, parent)
    local f = Instance.new("Frame")
    f.BorderSizePixel = 0
    for k, v in pairs(props or {}) do f[k] = v end
    if parent then f.Parent = parent end
    return f
end

local function Label(props, parent)
    local l = Instance.new("TextLabel")
    l.BorderSizePixel  = 0
    l.BackgroundTransparency = 1
    l.Font = Enum.Font.GothamSemibold
    l.TextSize = 13
    l.TextXAlignment = Enum.TextXAlignment.Left
    for k, v in pairs(props or {}) do l[k] = v end
    if parent then l.Parent = parent end
    return l
end

local function Button(props, parent)
    local b = Instance.new("TextButton")
    b.BorderSizePixel = 0
    b.AutoButtonColor = false
    b.Font = Enum.Font.GothamSemibold
    b.TextSize = 13
    for k, v in pairs(props or {}) do b[k] = v end
    if parent then b.Parent = parent end
    return b
end

local function Scroll(props, parent)
    local s = Instance.new("ScrollingFrame")
    s.BorderSizePixel = 0
    s.ScrollBarThickness = 3
    s.BottomImage = "rbxasset://textures/ui/Scroll/scroll-middle.png"
    s.TopImage    = "rbxasset://textures/ui/Scroll/scroll-middle.png"
    s.MidImage    = "rbxasset://textures/ui/Scroll/scroll-middle.png"
    for k, v in pairs(props or {}) do s[k] = v end
    if parent then s.Parent = parent end
    return s
end

local function List(dir, pad, parent)
    local l = Instance.new("UIListLayout")
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.SortOrder     = Enum.SortOrder.LayoutOrder
    l.Padding       = UDim.new(0, pad or 0)
    if parent then l.Parent = parent end
    return l
end

