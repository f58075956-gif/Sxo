        function Tab:AddSlider(title, callback, opts, desc)
            opts = opts or {}
            callback = callback or function() end
            local minV = opts.min or opts.Min or 0
            local maxV = opts.max or opts.Max or 100
            local defV = opts.Default or minV
            local round = opts.Rounding or 0
            local readonly = opts.readonly or false

            local el = Fr({ Size=UDim2.new(1,0,0,50), BackgroundColor3=theme.ElementBg }, tabContent)
            C(8,el); S(theme.ElementStroke,1,0.6,el)
            el.MouseEnter:Connect(function() T(el,{BackgroundColor3=theme.ElementHover}) end)
            el.MouseLeave:Connect(function() T(el,{BackgroundColor3=theme.ElementBg}) end)

            Lbl({ Text=title, Size=UDim2.new(1,-170,0,14), Position=UDim2.fromOffset(14,10),
