-- ── AddToggle ────────────────────────────
function Elements:AddToggle(idx, config)
    local ctrl = { Value = config.Default == true, Type="Toggle" }
    Library.Options[idx] = ctrl

    local el = makeElement(config.Title, config.Description, self.Container, true)

    local track = New("TextButton",{
        Size             = UDim2.fromOffset(40,20),
        AnchorPoint      = Vector2.new(1,0.5),
        Position         = UDim2.new(1,-10,0.5,0),
        BackgroundColor3 = ctrl.Value and Library.Accent or theme("Third"),
        Text             = "",
        AutoButtonColor  = false,
        ZIndex           = el.Frame.ZIndex+1,
        Parent           = el.Frame,
    },{
        New("UICorner",{CornerRadius=UDim.new(1,0)}),
        New("UIStroke",{Transparency=0.5,Color=theme("InElementBorder"),ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
    })

    local thumb = New("Frame",{
        Size            = UDim2.fromOffset(14,14),
        AnchorPoint     = Vector2.new(0.5,0.5),
        Position        = ctrl.Value and UDim2.new(0,30,0.5,0) or UDim2.new(0,10,0.5,0),
        BackgroundColor3 = Color3.new(1,1,1),
        ZIndex          = track.ZIndex+1,
        Parent          = track,
    },{New("UICorner",{CornerRadius=UDim.new(1,0)})})

    local function refresh()
        T(track,{BackgroundColor3 = ctrl.Value and Library.Accent or theme("Third")}, 0.12)
        T(thumb,{Position = ctrl.Value and UDim2.new(0,30,0.5,0) or UDim2.new(0,10,0.5,0)}, 0.12)
    end

    track.MouseButton1Click:Connect(function()
        ctrl.Value = not ctrl.Value
        refresh()
        pcall(config.Callback or function()end, ctrl.Value)
        if ctrl.Changed then ctrl.Changed(ctrl.Value) end
    end)

    function ctrl:SetValue(v) ctrl.Value=v==true; refresh(); pcall(config.Callback or function()end,ctrl.Value) end
    function ctrl:OnChanged(fn) ctrl.Changed=fn end

    refresh()
    return ctrl
end

-- ── AddSlider ────────────────────────────
function Elements:AddSlider(idx, config)
    local minV  = config.Min     or 0
    local maxV  = config.Max     or 100
    local round = config.Rounding or 0
    local ctrl  = { Value = config.Default or minV, Type="Slider" }
    Library.Options[idx] = ctrl

    local el = makeElement(config.Title, config.Description, self.Container, false)
    el.Frame.AutomaticSize = Enum.AutomaticSize.None
    el.Frame.Size          = UDim2.new(1,0,0,50)

    local valLabel = New("TextLabel",{
        Size            = UDim2.fromOffset(45,14),
        AnchorPoint     = Vector2.new(1,0),
        Position        = UDim2.new(1,-10,0,13),
        BackgroundTransparency=1,
        Text            = tostring(ctrl.Value),
        TextColor3      = Library.Accent,
        TextSize        = 12,
        FontFace        = Font.new("rbxasset://fonts/families/GothamSSm.json",Enum.FontWeight.Medium),
        TextXAlignment  = Enum.TextXAlignment.Right,
        ZIndex          = el.Frame.ZIndex+1,
        Parent          = el.Frame,
    })

    local trackBg = New("Frame",{
        Size            = UDim2.new(1,-20,0,5),
        AnchorPoint     = Vector2.new(0,1),
        Position        = UDim2.new(0,10,1,-10),
        BackgroundColor3= theme("Third"),
        ZIndex          = el.Frame.ZIndex+1,
        Parent          = el.Frame,
    },{
        New("UICorner",{CornerRadius=UDim.new(1,0)}),
        New("UIStroke",{Transparency=0.6,Color=theme("InElementBorder"),ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
    })

    local fill = New("Frame",{
        Size            = UDim2.new(0,0,1,0),
        BackgroundColor3= Library.Accent,
        ZIndex          = trackBg.ZIndex+1,
        Parent          = trackBg,
    },{New("UICorner",{CornerRadius=UDim.new(1,0)})})

    local knob = New("Frame",{
        Size            = UDim2.fromOffset(14,14),
        AnchorPoint     = Vector2.new(0.5,0.5),
        Position        = UDim2.new(0,0,0.5,0),
        BackgroundColor3= Color3.new(1,1,1),
        ZIndex          = fill.ZIndex+1,
        Parent          = trackBg,
    },{New("UICorner",{CornerRadius=UDim.new(1,0)})})

    local dragging = false

    local function applyPct(pct)
        pct = math.clamp(pct,0,1)
        local raw = minV + (maxV-minV)*pct
        local val = round > 0 and math.floor(raw*(10^round)+0.5)/(10^round) or math.floor(raw+0.5)
        ctrl.Value = val
        valLabel.Text = tostring(val)
        fill.Size  = UDim2.new(pct,0,1,0)
        knob.Position = UDim2.new(pct,0,0.5,0)
        pcall(config.Callback or function()end, val)
        if ctrl.Changed then ctrl.Changed(val) end
    end

    trackBg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local mp = mousePos()
            applyPct((mp.X - trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X)
        end
    end)
    addSignal(UIS.InputChanged, function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local mp = mousePos()
            applyPct((mp.X - trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X)
        end
    end)
    addSignal(UIS.InputEnded, function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
    end)

    function ctrl:SetValue(v)
        v = tonumber(v) or minV
        applyPct((v-minV)/(maxV-minV))
    end
    function ctrl:OnChanged(fn) ctrl.Changed=fn; fn(ctrl.Value) end

    ctrl:SetValue(config.Default or minV)
    return ctrl
end

