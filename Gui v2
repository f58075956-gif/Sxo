    ll2:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        listFrame.CanvasSize = UDim2.new(0,0,0,ll2.AbsoluteContentSize.Y)
    end)

    local panel = New("Frame",{
        Size            = UDim2.new(0,160,0,0),
