local function makeElement(title, desc, parent, hover)
    local el = {}

    el.TitleLabel = New("TextLabel", {
        FontFace            = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium),
        Text                = title or "",
        TextColor3          = theme("Text"),
        TextSize            = 13,
        TextXAlignment      = Enum.TextXAlignment.Left,
        Size                = UDim2.new(1,0,0,14),
        BackgroundTransparency = 1,
    })

    el.DescLabel = New("TextLabel", {
        FontFace            = Font.new("rbxasset://fonts/families/GothamSSm.json"),
        Text                = desc or "",
        TextColor3          = theme("SubText"),
        TextSize            = 11,
        TextWrapped         = true,
        TextXAlignment      = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        AutomaticSize       = Enum.AutomaticSize.Y,
        Size                = UDim2.new(1,0,0,0),
        Visible             = desc ~= nil and desc ~= "",
    })

    el.LabelHolder = New("Frame", {
        AutomaticSize       = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Position            = UDim2.fromOffset(10, 0),
        Size                = UDim2.new(0.55, -10, 0, 0),
    }, {
        listLayout(nil, nil, Enum.VerticalAlignment.Center, 2, nil),
        New("UIPadding",{
            PaddingTop    = UDim.new(0,13),
            PaddingBottom = UDim.new(0,13),
        }),
        el.TitleLabel,
        el.DescLabel,
    })
    el.LabelHolder:GetChildren()[1].Parent = el.LabelHolder -- layout
    el.TitleLabel.Parent  = el.LabelHolder
    el.DescLabel.Parent   = el.LabelHolder

    el.Border = New("UIStroke", {
        Transparency      = 0.5,
        ApplyStrokeMode   = Enum.ApplyStrokeMode.Border,
        Color             = theme("ElementBorder"),
    })

    el.Frame = New("TextButton", {
        Size                = UDim2.new(1,0,0,0),
        BackgroundTransparency = theme("ElementTransparency"),
        BackgroundColor3    = theme("Element"),
        Parent              = parent,
        AutomaticSize       = Enum.AutomaticSize.Y,
        Text                = "",
    }, {
        New("UICorner",{ CornerRadius = UDim.new(0,4) }),
        el.Border,
        el.LabelHolder,
    })

    if hover then
        local et = theme("ElementTransparency")
        local hc = theme("HoverChange")
        el.Frame.MouseEnter:Connect(function()    T(el.Frame,{BackgroundTransparency=et-hc},0.08) end)
        el.Frame.MouseLeave:Connect(function()    T(el.Frame,{BackgroundTransparency=et},0.08)    end)
        el.Frame.MouseButton1Down:Connect(function() T(el.Frame,{BackgroundTransparency=et+hc},0.05) end)
        el.Frame.MouseButton1Up:Connect(function()   T(el.Frame,{BackgroundTransparency=et-hc},0.05) end)
    end

    function el:SetTitle(t2) el.TitleLabel.Text = t2 end
    function el:SetDesc(d2)
        el.DescLabel.Text    = d2 or ""
        el.DescLabel.Visible = (d2 ~= nil and d2 ~= "")
    end
    function el:Destroy() el.Frame:Destroy() end

    return el
end

