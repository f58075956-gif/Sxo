function Elements:AddKeybind(idx, config)
    local ctrl = {
        Value   = config.Default or "None",
        Mode    = config.Mode or "Toggle",
        Toggled = false,
        Type    = "Keybind",
    }
    Library.Options[idx] = ctrl

    local el = makeElement(config.Title, config.Description, self.Container, true)

    local dispLabel = New("TextLabel",{
        FontFace        = Font.new("rbxasset://fonts/families/GothamSSm.json"),
        Text            = ctrl.Value,
        TextColor3      = theme("Text"),
        TextSize        = 13,
        TextXAlignment  = Enum.TextXAlignment.Center,
        Size            = UDim2.fromOffset(0,14),
        AutomaticSize   = Enum.AutomaticSize.X,
        BackgroundTransparency=1,
    })
    local kbBtn = New("TextButton",{
        Size            = UDim2.fromOffset(0,30),
        AnchorPoint     = Vector2.new(1,0.5),
        Position        = UDim2.new(1,-10,0.5,0),
        AutomaticSize   = Enum.AutomaticSize.X,
        BackgroundTransparency=0.9,
        BackgroundColor3= theme("Keybind"),
        Text            = "",
        AutoButtonColor = false,
        ZIndex          = el.Frame.ZIndex+1,
        Parent          = el.Frame,
    },{
        New("UICorner",{CornerRadius=UDim.new(0,5)}),
        New("UIStroke",{Transparency=0.5,Color=theme("InElementBorder"),ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
        New("UIPadding",{PaddingLeft=UDim.new(0,8),PaddingRight=UDim.new(0,8)}),
        dispLabel,
    })

    local picking=false
    kbBtn.MouseButton1Click:Connect(function()
        if picking then return end
        picking=true
        dispLabel.Text="..."
        local c; c = UIS.InputBegan:Connect(function(inp,gp)
            if gp then return end
            if inp.KeyCode and inp.KeyCode~=Enum.KeyCode.Unknown then
                ctrl.Value=inp.KeyCode.Name
                dispLabel.Text=ctrl.Value
                picking=false
                c:Disconnect()
                if ctrl.ChangedCallback then ctrl.ChangedCallback(inp.KeyCode) end
            end
        end)
    end)

    addSignal(UIS.InputBegan, function(inp,gp)
        if gp or picking then return end
        local kc = ctrl.Value
        if inp.KeyCode.Name==kc or inp.UserInputType.Name==kc then
            if ctrl.Mode=="Toggle" then
                ctrl.Toggled=not ctrl.Toggled
                pcall(config.Callback or function()end,ctrl.Toggled)
                if ctrl.Clicked then ctrl.Clicked(ctrl.Toggled) end
            elseif ctrl.Mode=="Hold" then
                ctrl.Toggled=true
                pcall(config.Callback or function()end,true)
            elseif ctrl.Mode=="Always" then
                pcall(config.Callback or function()end,true)
            end
        end
    end)
    addSignal(UIS.InputEnded, function(inp)
        if ctrl.Mode=="Hold" then
            if inp.KeyCode.Name==ctrl.Value or inp.UserInputType.Name==ctrl.Value then
                ctrl.Toggled=false
                pcall(config.Callback or function()end,false)
            end
        end
    end)

    function ctrl:SetValue(key,mode)
        ctrl.Value = type(key)=="string" and key or key.Name
        if mode then ctrl.Mode=mode end
        dispLabel.Text=ctrl.Value
    end
    function ctrl:GetState() return ctrl.Toggled end
    function ctrl:OnClick(fn) ctrl.Clicked=fn end
    function ctrl:OnChanged(fn) ctrl.ChangedCallback=fn end
    return ctrl
end

