        ZIndex          = hueBar.ZIndex+1,
        Parent          = hueBar,
    },{New("UICorner",{CornerRadius=UDim.new(1,0)})})

    -- Barra de Value (V)
    local satBar = New("ImageLabel",{
        Size            = UDim2.new(1,-128,0,14),
        Position        = UDim2.fromOffset(128,20),
        Image           = "rbxassetid://3641079629",
        BackgroundColor3= Color3.fromHSV(h,1,1),
        ZIndex          = panel.ZIndex+1,
        Parent          = panel,
    },{New("UICorner",{CornerRadius=UDim.new(1,0)})})
    local satKnob = New("Frame",{
        Size            = UDim2.fromOffset(4,18),
        AnchorPoint     = Vector2.new(0.5,0.5),
        Position        = UDim2.new(1-v,0,0.5,0),
        BackgroundColor3= Color3.new(1,1,1),
        ZIndex          = satBar.ZIndex+1,
        Parent          = satBar,
    },{New("UICorner",{CornerRadius=UDim.new(1,0)})})

    local function updateColor()
        local c = Color3.fromHSV(h,s,v)
        ctrl.Value    = c
        preview.BackgroundColor3  = c
        palette.BackgroundColor3  = Color3.fromHSV(h,1,1)
        satBar.ImageColor3        = Color3.fromHSV(h,1,1)
        cursor.Position  = UDim2.new(s,0,1-v,0)
        hueKnob.Position = UDim2.new(h,0,0.5,0)
        satKnob.Position = UDim2.new(1-v,0,0.5,0)
        pcall(config.Callback or function()end,c)
        if ctrl.Changed then ctrl.Changed(c) end
    end

    local dragP,dragH,dragS=false,false,false
    palette.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragP=true end end)
    hueBar.InputBegan:Connect(function(i)  if i.UserInputType==Enum.UserInputType.MouseButton1 then dragH=true end end)
    satBar.InputBegan:Connect(function(i)  if i.UserInputType==Enum.UserInputType.MouseButton1 then dragS=true end end)

    addSignal(UIS.InputChanged, function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local mp = mousePos()
        if dragP then
            s = math.clamp((mp.X-palette.AbsolutePosition.X)/palette.AbsoluteSize.X,0,1)
            v = 1-math.clamp((mp.Y-palette.AbsolutePosition.Y)/palette.AbsoluteSize.Y,0,1)
            updateColor()
        end
        if dragH then
            h = math.clamp((mp.X-hueBar.AbsolutePosition.X)/hueBar.AbsoluteSize.X,0,1)
            updateColor()
        end
        if dragS then
            v = 1-math.clamp((mp.X-satBar.AbsolutePosition.X)/satBar.AbsoluteSize.X,0,1)
            updateColor()
        end
    end)
    addSignal(UIS.InputEnded, function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragP=false;dragH=false;dragS=false end
    end)

    local panelOpen=false
    preview.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            panelOpen=not panelOpen
            panel.Visible=panelOpen
        end
    end)
    el.Frame.MouseButton1Click:Connect(function()
        panelOpen=not panelOpen
        panel.Visible=panelOpen
    end)

    function ctrl:SetValueRGB(c) local hh,ss,vv=Color3.toHSV(c); h=hh;s=ss;v=vv; updateColor() end
    function ctrl:OnChanged(fn) ctrl.Changed=fn end

    updateColor()
    return ctrl
end

