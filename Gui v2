            if isMulti then
                ctrl.Value[name] = not ctrl.Value[name]
                T(ob,{BackgroundColor3= ctrl.Value[name] and Library.Accent or theme("Third"),
                      BackgroundTransparency= ctrl.Value[name] and 0.7 or 1},0.1)
                updateDisplay()
                pcall(config.Callback or function()end, ctrl.Value)
                if ctrl.Changed then ctrl.Changed(ctrl.Value) end
            else
                -- reset todos
                for _,b2 in pairs(buttons) do
                    T(b2,{BackgroundTransparency=1,BackgroundColor3=theme("Third")},0.08)
                end
                T(ob,{BackgroundColor3=Library.Accent,BackgroundTransparency=0.7},0.1)
                ctrl.Value=name
                updateDisplay()
                close()
                pcall(config.Callback or function()end, name)
                if ctrl.Changed then ctrl.Changed(name) end
            end
        end)
        buttons[name]=ob
        -- expandir panel si abierto
        if opened then
            local h=math.min(ll2.AbsoluteContentSize.Y+10,180)
            T(panel,{Size=UDim2.new(0,160,0,h)},0.12)
        end
    end

    for _,v in ipairs(config.Values or {}) do addOption(v) end

    function ctrl:SetValue(v)
        if isMulti then
            for k in pairs(ctrl.Value) do ctrl.Value[k]=false end
            if type(v)=="table" then for k,s in pairs(v) do ctrl.Value[k]=s end end
        else
            ctrl.Value=v
        end
        updateDisplay()
        pcall(config.Callback or function()end,ctrl.Value)
    end
    function ctrl:AddValue(name)  addOption(name) end
    function ctrl:RemoveValue(n)
        if buttons[n] then buttons[n]:Destroy(); buttons[n]=nil end
    end
    function ctrl:OnChanged(fn) ctrl.Changed=fn end

    if config.Default then ctrl:SetValue(config.Default) end
    return ctrl
end

