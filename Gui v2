                              or  UDim2.fromOffset(Root.AbsoluteSize.X,WinSize.Y)},0.15)
    end)

    -- ── Drag ───────────────────────────────
    local drag,dragStart,startPos=false,nil,nil
    TitleBar.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true; dragStart=inp.Position; startPos=Root.Position
        end
    end)
    addSignal(UIS.InputChanged,function(inp)
        if drag and inp.UserInputType==Enum.UserInputType.MouseMovement then
            local d=inp.Position-dragStart
            Root.Position=UDim2.fromOffset(startPos.X.Offset+d.X, startPos.Y.Offset+d.Y)
        end
    end)
    addSignal(UIS.InputEnded,function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)

    -- ── Panel izquierdo de Tabs (Fluent: 160px, fondo Second) ──
    local tabPanel = New("Frame",{
        Size            = UDim2.new(0,TabWidth,1,-42),
        Position        = UDim2.fromOffset(0,42),
        BackgroundColor3= theme("Second"),
        BorderSizePixel = 0,
        Parent          = Root,
    })
    -- Esquinas redondeadas solo inf-izq
    New("UICorner",{CornerRadius=UDim.new(0,8),Parent=tabPanel})
    New("Frame",{  -- cuadrar esquinas top
        Size=UDim2.new(1,0,0.5,0); BackgroundColor3=theme("Second"); BorderSizePixel=0; Parent=tabPanel
    })
    New("Frame",{  -- cuadrar esquina inf-der
        Size=UDim2.new(0.5,0,0.5,0); Position=UDim2.new(0.5,0,0.5,0);
        BackgroundColor3=theme("Second"); BorderSizePixel=0; Parent=tabPanel
    })

    -- Indicador de pestaña activa (barra azul izquierda)
    local selector = New("Frame",{
        Size            = UDim2.fromOffset(4,0),
        Position        = UDim2.fromOffset(0,17),
        BackgroundColor3= Library.Accent,
        ZIndex          = tabPanel.ZIndex+2,
        Parent          = tabPanel,
    },{New("UICorner",{CornerRadius=UDim.new(0,2)})})

    -- ScrollingFrame que contiene los botones de tabs
    local tabHolder = New("ScrollingFrame",{
        Size                    = UDim2.new(1,0,1,0),
        BackgroundTransparency  = 1,
        ScrollBarThickness      = 0,
        CanvasSize              = UDim2.fromScale(0,0),
        ScrollingDirection      = Enum.ScrollingDirection.Y,
        Parent                  = tabPanel,
    })
    pad(8,8,8,8,tabHolder)
    local tabList = listLayout(nil,nil,nil,4,tabHolder)
    tabList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabHolder.CanvasSize=UDim2.new(0,0,0,tabList.AbsoluteContentSize.Y)
    end)

    -- ── Área de contenido (derecha) ────────
    -- Nombre de pestaña activa (grande, como Fluent)
    local tabDisplay = New("TextLabel",{
        RichText        = true,
        Text            = "Tab",
        FontFace        = Font.new("rbxassetid://12187365364",Enum.FontWeight.SemiBold),
        TextSize        = 28,
        TextXAlignment  = Enum.TextXAlignment.Left,
        TextYAlignment  = Enum.TextYAlignment.Center,
        Size            = UDim2.new(1,-16,0,28),
        Position        = UDim2.fromOffset(TabWidth+26, 54),
        BackgroundTransparency=1,
        TextColor3      = theme("Text"),
        Parent          = Root,
    })

    local containerCanvas = New("Frame",{
        Size            = UDim2.new(1,-TabWidth-32, 1,-100),
        Position        = UDim2.fromOffset(TabWidth+26, 90),
        BackgroundTransparency=1,
        ClipsDescendants= true,
        Parent          = Root,
    })

    -- ── Resize handle ─────────────────────
    local resizer = New("TextButton",{
        Size            = UDim2.fromOffset(16,16),
        AnchorPoint     = Vector2.new(1,1),
        Position        = UDim2.new(1,0,1,0),
        BackgroundColor3= theme("ElementBorder"),
        BackgroundTransparency=0.6,
        Text            = "",
        AutoButtonColor = false,
        ZIndex          = Root.ZIndex+5,
        Parent          = Root,
    },{New("UICorner",{CornerRadius=UDim.new(0,4)})})
    local resizing,resizeStart,startSize2=false,nil,nil
    resizer.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            resizing=true; resizeStart=i.Position; startSize2=Root.AbsoluteSize
        end
    end)
    addSignal(UIS.InputChanged,function(i)
        if resizing and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-resizeStart
            local nx=math.max(400,startSize2.X+d.X)
            local ny=math.max(300,startSize2.Y+d.Y)
            Root.Size=UDim2.fromOffset(nx,ny)
            WinSize=Vector2.new(nx,ny)
        end
    end)
    addSignal(UIS.InputEnded,function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then resizing=false end
    end)

    -- ═══════════════════════════════════════
    --  OBJETO WINDOW
    -- ═══════════════════════════════════════
    local Window = {}
    local tabs={}, selectedIdx=0

    local function selectTab(idx)
        if selectedIdx==idx then return end
        -- ocultar anterior
        if selectedIdx>0 and tabs[selectedIdx] then
            tabs[selectedIdx].ContainerFrame.Visible=false
            T(tabs[selectedIdx].Frame,{BackgroundTransparency=1},0.12)
            tabs[selectedIdx].Selected=false
        end
        selectedIdx=idx
        local tab=tabs[idx]
        tab.Selected=true
        tab.ContainerFrame.Visible=true
        T(tab.Frame,{BackgroundTransparency=0.89},0.12)
        tabDisplay.Text = tab.Name
        -- animar selector
        local relY = tab.Frame.AbsolutePosition.Y - tabHolder.AbsolutePosition.Y
        T(selector,{Position=UDim2.fromOffset(0,relY+tabHolder.CanvasPosition.Y+8),
                    Size=UDim2.fromOffset(4,tab.Frame.AbsoluteSize.Y-16)},0.15)
    end

    function Window:AddTab(title, icon)
        local tabIdx = #tabs+1

        local tabBtn = New("TextButton",{
            Size            = UDim2.new(1,0,0,34),
            BackgroundColor3= theme("Tab"),
            BackgroundTransparency=1,
            Text            = "",
            AutoButtonColor = false,
            Parent          = tabHolder,
        },{New("UICorner",{CornerRadius=UDim.new(0,6)})})

        -- Ícono
        if icon and icon~="" then
            New("ImageLabel",{
                AnchorPoint     = Vector2.new(0,0.5),
                Size            = UDim2.fromOffset(16,16),
                Position        = UDim2.fromOffset(8,17),
                BackgroundTransparency=1,
                Image           = "rbxassetid://0",  -- placeholder; usa URL de lucide si tienes
                ImageColor3     = theme("Text"),
                Parent          = tabBtn,
            })
        end
        New("TextLabel",{
            AnchorPoint     = Vector2.new(0,0.5),
            Position        = icon and UDim2.fromOffset(30,17) or UDim2.fromOffset(12,17),
            Text            = title,
            FontFace        = Font.new("rbxasset://fonts/families/GothamSSm.json"),
            TextSize        = 12,
            TextColor3      = theme("Text"),
            TextXAlignment  = Enum.TextXAlignment.Left,
            BackgroundTransparency=1,
            Size            = UDim2.new(1,-12,1,0),
            Parent          = tabBtn,
        })

        local containerFrame = New("ScrollingFrame",{
            Size                    = UDim2.fromScale(1,1),
            BackgroundTransparency  = 1,
            ScrollBarThickness      = 3,
            ScrollBarImageColor3    = theme("ScrollBar"),
            ScrollBarImageTransparency=0.5,
            CanvasSize              = UDim2.fromScale(0,0),
            ScrollingDirection      = Enum.ScrollingDirection.Y,
            Visible                 = false,
            Parent                  = containerCanvas,
        })
        pad(1,10,1,1,containerFrame)
        local cfl = listLayout(nil,nil,nil,5,containerFrame)
        cfl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            containerFrame.CanvasSize=UDim2.new(0,0,0,cfl.AbsoluteContentSize.Y+2)
        end)

        local tab = {
            Name           = title,
            Frame          = tabBtn,
            ContainerFrame = containerFrame,
            Container      = containerFrame,
            Selected       = false,
        }
        setmetatable(tab, Elements)

        -- Hover
        tabBtn.MouseEnter:Connect(function()
            if not tab.Selected then T(tabBtn,{BackgroundTransparency=0.89},0.1) end
        end)
        tabBtn.MouseLeave:Connect(function()
            if not tab.Selected then T(tabBtn,{BackgroundTransparency=1},0.1) end
        end)
        tabBtn.MouseButton1Down:Connect(function() T(tabBtn,{BackgroundTransparency=0.92},0.05) end)
        tabBtn.MouseButton1Click:Connect(function() selectTab(tabIdx) end)

        table.insert(tabs,tab)
        if tabIdx==1 then
            task.defer(function() selectTab(1) end)
        end
        return tab
    end

    function Window:SelectTab(idx) selectTab(idx) end
    function Window:Notify(cfg) Library:Notify(cfg) end
    function Window:Destroy() Root:Destroy() end
    function Window:Toggle() Root.Visible=not Root.Visible end
    function Window:SetTitle(t) tabDisplay.Text=t end

    table.insert(Library._windows, Window)
    return Window
end

-- ═══════════════════════════════════════════
--  DESTRUIR TODO
-- ═══════════════════════════════════════════
function Library:Destroy()
    for _,s in ipairs(Library._signals) do
        if s and s.Connected then s:Disconnect() end
    end
    Library._signals={}
    ScreenGui:Destroy()
end

return Library
