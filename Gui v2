        New("UIStroke",{Transparency=0.5,Color=theme("InElementBorder"),ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
    })
    pad(8,8,0,0,box)

    local function apply(text)
        if config.Numeric and not tonumber(text) and #text>0 then
            box.Text = ctrl.Value; return
        end
        ctrl.Value = text
        pcall(config.Callback or function()end, text)
        if ctrl.Changed then ctrl.Changed(text) end
    end

    if config.Finished then
        box.FocusLost:Connect(function(enter) if enter then apply(box.Text) end end)
    else
        box:GetPropertyChangedSignal("Text"):Connect(function() apply(box.Text) end)
    end

    function ctrl:SetValue(v) ctrl.Value=v; box.Text=v end
    function ctrl:OnChanged(fn) ctrl.Changed=fn; fn(ctrl.Value) end
    return ctrl
end

