-- Poll: recibe mensajes nuevos cada POLL_INTERVAL segundos
local function startPolling()
    task.spawn(function()
        while true do
            task.wait(POLL_INTERVAL)
            local ok, result = pcall(function()
                return HttpService:RequestAsync({
                    Url    = GLOBAL_SERVER_URL .. "/messages?after=" .. lastSeenId .. "&game=" .. GAME_FILTER,
                    Method = "GET",
                })
            end)

            if ok and result and result.StatusCode == 200 then
                if not isConnected then
                    isConnected = true
                    updateTitle(true)
                end

                local data = HttpService:JSONDecode(result.Body)
                lastSeenId = data.lastId or lastSeenId

                for _, msg in ipairs(data.msgs or {}) do
                    -- Comandos de moderaciÃ³n del servidor
                    if msg.sender == "__CMD__" then
                        local cmd = msg.text or ""
                        if cmd:sub(1,5) == "MUTE:" then
                            local uid, exp = cmd:match("MUTE:(%d+):(.*)")
                            if uid then
                                mutes[uid] = { expiry = (exp ~= "nil") and tonumber(exp) or nil }; saveMutes()
                                if uid == tostring(lplr.UserId) then applyMuteState() end
                            end
                        elseif cmd:sub(1,7) == "UNMUTE:" then
                            local uid = cmd:match("UNMUTE:(%d+)")
                            if uid then mutes[uid] = nil; saveMutes()
                                if uid == tostring(lplr.UserId) then applyMuteState() end
                            end
                        elseif cmd:sub(1,4) == "BAN:" then
                            local uid, exp = cmd:match("BAN:(%d+):(.*)")
                            if uid then bans[uid] = { expiry = (exp ~= "nil") and tonumber(exp) or nil }; saveBans() end
                        elseif cmd:sub(1,6) == "UNBAN:" then
                            local uid = cmd:match("UNBAN:(%d+)")
                            if uid then bans[uid] = nil; saveBans() end
                        elseif cmd:sub(1,6) == "CLEAR:" then
                            for _, c in ipairs(ScrollFrame:GetChildren()) do
                                if c:IsA("Frame") then c:Destroy() end
                            end
                            messageCount = 0
                            sysMsg("Chat limpiado por " .. cmd:match("CLEAR:(.+)") .. ".")
                        elseif cmd:sub(1,5) == "EDIT:" then
                            local uid, newText = cmd:match("^EDIT:([%d%-]+):(.*)$")
                            if uid then applyEditToFrame(uid, newText) end
                        end
                        continue
                    end

                    -- Ignorar mis propios mensajes (ya los mostrÃ© al enviar)
                    if sentUids[msg.uid] then continue end
                    if msg.sender == tostring(lplr.UserId) then continue end

                    -- Filtros de ban/mute
                    if isBanned(msg.sender) or isMuted(msg.sender) then continue end

                    checkSpam(msg.sender)

                    local quote = nil
                    if msg.quoteName and msg.quoteName ~= "" then
                        quote = { name = msg.quoteName, text = msg.quoteText or "" }
                    end

                    local rankKey = (msg.rank ~= "" and msg.rank ~= nil) and msg.rank or nil
                    addMessage(msg.display, msg.sender, msg.text, false, rankKey, false, quote, msg.uid)
                end
            else
                if isConnected then
                    isConnected = false
                    updateTitle(false)
                end
            end
        end
    end)
end

