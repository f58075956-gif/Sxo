--  ANTI-SPAM LOCAL
-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
local SPAM_LIMIT  = 6
local SPAM_WINDOW = 1800
local spamTracker = {}

local function checkSpam(uid)
    if getRankLevel(uid) >= 3 then return end
    local key  = tostring(uid)
    local now  = os.time()
    local list = spamTracker[key] or {}
    local fresh = {}
    for _, t in ipairs(list) do
        if now - t < SPAM_WINDOW then table.insert(fresh, t) end
    end
    table.insert(fresh, now)
    spamTracker[key] = fresh
    if #fresh > SPAM_LIMIT then
        spamTracker[key] = nil
        local expiry = now + SPAM_WINDOW
        mutes[key] = { expiry = expiry }; saveMutes()
        if tostring(lplr.UserId) == key then applyMuteState() end
        local p = Players:GetPlayerByUserId(tonumber(uid))
        sysMsg((p and p.DisplayName or ("UserId " .. key)) .. " fue muteado por spam (30 min).")
    end
end

