            end
            ranks[tostring(t.UserId)] = rankStr; saveRanks()
            sysMsg(t.DisplayName .. " ahora es " .. RANK_INFO[rankStr].label .. ".")
        else
            sysMsg("Rango invÃ¡lido: owner | admin | mod | none")
