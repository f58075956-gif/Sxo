local function sendMessage()
    closeMentionPopup()
    local text = ChatInput.Text
    if text == "" then return end
    ChatInput.Text = ""

    -- Modo ediciÃ³n
    if editingUID then
        if #text > 200 then sysMsg("Mensaje muy largo (mÃ¡x 200).") return end
        local uid = editingUID
        applyEditToFrame(uid, text)
        httpCmd("EDIT:" .. uid .. ":" .. text)
        clearBar(); return
    end

    if handleCommand(text) then return end
    if #text > 200 then sysMsg("Mensaje muy largo (mÃ¡x 200 caracteres).") return end
    if isBanned(lplr.UserId)  then sysMsg("EstÃ¡s baneado del chat.") return end
    if isMuted(lplr.UserId)   then sysMsg("EstÃ¡s muteado, no puedes escribir.") return end

    checkSpam(lplr.UserId)

    local myRank = getRank(lplr.UserId)
    local quote  = replyTarget and { name = replyTarget.name, text = replyTarget.text } or nil
    local uid    = tostring(lplr.UserId) .. "-" .. tostring(os.time()) .. "-" .. tostring(math.random(10000,99999))

    -- Mostrar inmediatamente en mi pantalla
    addMessage(lplr.DisplayName, lplr.UserId, text, true, myRank, false, quote, uid)
    sentUids[uid] = true   -- marcar para no duplicar al recibirlo del servidor

    -- Enviar al servidor global
    httpSend({
        userId    = tostring(lplr.UserId),
        display   = lplr.DisplayName,
        text      = text,
        rank      = myRank or "",
        quoteName = quote and quote.name or "",
        quoteText = quote and quote.text or "",
        uid       = uid,
        game      = GAME_FILTER,
    })

    clearBar()
end

